{
  "schema_version": "0.9",
  "description": "Vendor intake triage eval dataset. Each case captures a vendor onboarding scenario and the expected agent verdict. Materialized cases have real fixture documents under cases/<id>/; designed cases document intended coverage and ship without fixtures.",
  "coverage_dimensions": {
    "risk_tier": ["low", "medium", "high"],
    "vendor_stage": ["new", "renewal", "amendment", "expansion"],
    "data_sensitivity": ["none", "public", "internal", "pii", "restricted_pii", "restricted_phi"],
    "acv_band_usd": ["<10k", "10-50k", "50-100k", "100-500k", ">500k"],
    "ai_involvement": ["none", "general", "training_on_customer_data"],
    "doc_completeness": ["complete", "missing_w9", "missing_security_artifact", "missing_dpa", "missing_ai_optout", "multiple_missing"]
  },
  "scoring_rubric": {
    "flag_count_within_range": "+1 if actual is inside expected.flag_count.range",
    "flag_count_exact": "+1 if actual equals expected.flag_count.target",
    "action_match": "+1 if actual recommended_action equals expected.recommended_action",
    "risk_match": "+1 if actual risk_tier equals expected.risk_tier",
    "severity_mix_block_match": "+1 if (actual has any block-severity flag) equals (expected.severity_mix.block > 0)",
    "max_per_case": 5
  },
  "cases": [
    {
      "id": "case_001",
      "vendor_name": "Northstar Analytics",
      "status": "materialized",
      "fixture_dir": "cases/case_001/",
      "inputs": {
        "vendor_category": "data_analytics_saas",
        "vendor_stage": "new",
        "acv_usd": 85000,
        "one_time_usd": 10000,
        "term_months": 24,
        "payment_terms": "Net 30",
        "data_sensitivity": "pii",
        "ai_involvement": "general",
        "subprocessor_region": "EU",
        "docs_present": ["intake_xlsx", "quote_csv", "vendor_email", "security_questionnaire", "contract_pdf"],
        "open_items": ["soc2_type_ii_pending", "executed_dpa_pending"]
      },
      "expected": {
        "flag_count": { "target": 3, "range": [2, 4] },
        "recommended_action": "approve_with_followup",
        "risk_tier": "medium",
        "severity_mix": { "block": 0, "warn": 2, "info": 1 },
        "approvers_routed": ["procurement_manager", "vp_finance", "legal", "security"]
      },
      "coverage_tags": ["risk:medium", "stage:new", "data:pii", "acv:50-100k", "subprocessor:eu"],
      "notes": "Most-common shape — mid-market new vendor with PII and two open items. Tests routing breadth (4 approvers) and warn-not-block discrimination. The two open items (SOC 2 II pending, DPA pending) are correctable via vendor follow-up rather than blocking."
    },
