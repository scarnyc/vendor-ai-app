# Vendor AI — environment variables
# Copy to .env.local for local dev. Real values live in Vercel env vars (server-side only).

# LLM provider switch — mock | openrouter | deepseek-direct
LLM_PROVIDER=mock

# OpenRouter (free :free models). Required when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# DeepSeek native Anthropic-compat endpoint (optional production-quality demo).
# Required only when LLM_PROVIDER=deepseek-direct.
DEEPSEEK_API_KEY=

# LangSmith tracing (P0 — one env var, free observability)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vendor-ai
LANGSMITH_TRACING=true

# CopilotKit runtime — public URL of this app
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit
