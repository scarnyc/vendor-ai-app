# Vendor AI — environment variables
# Copy to .env.local for local dev. Real values live in Vercel env vars (server-side only).

# LLM provider switch — mock | anthropic | anthropic-only | deepseek-only | openrouter
#   mock             → no network, fixtures keyed by case_id (dev/CI default)
#   anthropic        → Anthropic Sonnet 4.6 + thinking PRIMARY, DeepSeek fallback if
#                      DEEPSEEK_API_KEY is set (production demo path)
#   anthropic-only   → Anthropic only (no fallback) — fail loud on Anthropic errors
#   deepseek-only    → DeepSeek only (no fallback) — cost lane
#   openrouter       → OpenRouter only (free :free-tier models)
LLM_PROVIDER=mock

# Anthropic Claude Sonnet 4.6 — required when LLM_PROVIDER=anthropic or anthropic-only.
# Extended thinking is always on (budget_tokens default 10000). Temperature is
# forced to 1 by the API when thinking is enabled.
ANTHROPIC_API_KEY=
# Optional model + thinking budget overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_THINKING_BUDGET=10000

# DeepSeek native endpoint. Required when LLM_PROVIDER=deepseek-only, or when
# LLM_PROVIDER=anthropic and you want DeepSeek as the structured-output fallback.
DEEPSEEK_API_KEY=
# Optional model override (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# OpenRouter — used only when LLM_PROVIDER=openrouter (free :free-tier models).
OPENROUTER_API_KEY=
# Optional model override (default: deepseek/deepseek-chat:free)
# OPENROUTER_MODEL=deepseek/deepseek-chat:free

# LangSmith tracing (P0 — one env var, free observability)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vendor-ai
LANGSMITH_TRACING=true

# CopilotKit runtime — public URL of this app
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit
